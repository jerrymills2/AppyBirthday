{
  "expo": {
    "name": "Appy Birthday",
    "slug": "appy-birthday",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#E6F1FB"
    },
    "ios": {
      "bundleIdentifier": "com.yourname.appybirthday",
      "supportsTablet": false,
      "infoPlist": {
        "NSCalendarsUsageDescription": "To add birthdays to your calendar",
        "NSContactsUsageDescription": "To import contact information"
      }
    },
    "android": {
      "package": "com.yourname.appybirthday",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#185FA5"
      },
      "permissions": [
        "NOTIFICATIONS",
        "READ_CALENDAR",
        "WRITE_CALENDAR"
      ]
    },
    "plugins": [
      "expo-notifications",
      "expo-sqlite",
      "expo-asset"
    ]
  }
}
